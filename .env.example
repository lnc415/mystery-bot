# ─────────────────────────────────────────────
#  MYSTERY BOT — Environment Configuration
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Discord
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_guild_id_here   # optional: for guild-only slash commands

# ── LICENSE ──────────────────────────────────
# Licenses are now PER SERVER (per Discord guild).
# Each server activates its own key via /license in Discord.
# The env vars below are for legacy / global fallback only.
LICENSE_KEY=

# For server-side validation (optional — falls back to local keys.json)
# Point to your dashboard URL (e.g., https://your-domain.com)
LICENSE_API_URL=

# HMAC signing secret for API response verification
LICENSE_SIGNING_SECRET=

# ── DASHBOARD URL (shown in /configure command) ──────────────
# URL of your purchase page — shown to server admins who haven't licensed yet
DASHBOARD_URL=http://localhost:3001/buy

# ── MODULE TOGGLES (free tier) ───────────────
# Set to "true" to enable. Paid modules require a valid LICENSE_KEY.
ENABLE_GIFBOT=true
ENABLE_CHATBOT=false     # requires license or self-host key below
ENABLE_BUYBOT=false      # requires license
ENABLE_SELLBOT=false     # requires license
ENABLE_LIQUIDITY=false   # requires license

# ── AI CHATBOT ───────────────────────────────
# Provider: groq | openai | anthropic
AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model to use (provider-specific)
# Groq:      llama-3.3-70b-versatile | mixtral-8x7b-32768 | gemma2-9b-it
# OpenAI:    gpt-4o-mini | gpt-4o
# Anthropic: claude-haiku-4-5-20251001 | claude-sonnet-4-6
AI_MODEL=llama-3.3-70b-versatile

# Bot persona (system prompt — customize per project)
BOT_NAME=Chuck
BOT_PERSONA="You are Chuck, a goofy kid detective obsessed with solving the mystery of $141. You speak in short punchy sentences, drop detective lingo, and always tie things back to Cardano and ADA. Keep it fun, light, and never give financial advice."

# Channel where the chatbot responds (channel ID or "all")
CHATBOT_CHANNEL=all
# Reply to all messages or only when @mentioned
CHATBOT_TRIGGER=mention   # mention | all

# ── BUY / SELL / LIQUIDITY BOT ───────────────
# Blockchain source: blockfrost | taptools
CHAIN_SOURCE=blockfrost

# Blockfrost (https://blockfrost.io — free tier: 50k req/day)
BLOCKFROST_PROJECT_ID=mainnetXXXXXXXXXXXXXXXX
# Network: mainnet | preprod | preview | midnight
BLOCKFROST_NETWORK=mainnet

# TapTools — primary DEX trade source (get key at taptools.io)
TAPTOOLS_API_KEY=

# DexHunter — secondary DEX aggregator source (get key at dexhunter.io)
DEXHUNTER_API_KEY=

# Blockfrost — fallback, raw on-chain data (get free project ID at blockfrost.io — 50k req/day free)
# Note: BLOCKFROST_PROJECT_ID below also covers this. BLOCKFROST_API_KEY is an alias.
BLOCKFROST_API_KEY=

# Polling interval in milliseconds for the DEX monitor (default: 30000 = 30 seconds)
POLL_INTERVAL_MS=30000

# Token to monitor
TOKEN_POLICY_ID=your_token_policy_id_here
TOKEN_NAME=141             # hex or ASCII name
TOKEN_TICKER=$141

# Minimum ADA value to trigger a buy alert
BUY_MIN_ADA=10

# Discord channel IDs for alerts
BUY_ALERT_CHANNEL=your_buy_channel_id
SELL_ALERT_CHANNEL=your_sell_channel_id
LIQUIDITY_ALERT_CHANNEL=your_liquidity_channel_id

# Poll interval in seconds (lower = more API calls)
POLL_INTERVAL=30

# ── GIF BOT ──────────────────────────────────
# Source: local | url
GIF_SOURCE=local
# Local folder path (absolute) or URL prefix of a cloud folder
GIF_PATH=./gifs
# Command to trigger gif (default: /gif)
GIF_COMMAND=gif
# Channels where gif command works ("all" or comma-separated IDs)
GIF_CHANNELS=all

# ── GOOGLE DRIVE (for GIF Bot image source) ──
# Required if you want to pull GIFs from a Google Drive folder.
# How to get one:
#   1. Go to https://console.cloud.google.com
#   2. Create a project (or select an existing one)
#   3. Enable the "Google Drive API" (APIs & Services → Library → search Drive)
#   4. Go to APIs & Services → Credentials → Create Credentials → API Key
#   5. No restrictions needed for public (read-only) folder access
#   6. Copy the key here
# Per-server folder URLs are set in Discord via: /configure drive:<url>
GOOGLE_API_KEY=your_google_api_key_here
