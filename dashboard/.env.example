# ── Dashboard Configuration ──────────────────────────────────
# Copy to .env and fill in your values

# Dashboard server port
DASHBOARD_PORT=3001

# Domain for Stripe success/cancel redirects (no trailing slash)
DOMAIN=http://localhost:3001

# ── Stripe (optional but required for auto-licensing) ────────
# Get these from https://dashboard.stripe.com
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (optional — for sending license keys to customers) ─
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mystery-bot.com
